# Copy to .env and fill in.

# Where the Swift app writes its SQLite store (default shown).
FOMI4ME_DB=~/Library/Application Support/FomiForMe/fomi4me.sqlite

# Accountability partners, comma-separated.
PARTNER_EMAILS=partner1@example.com,partner2@example.com

# Review mode (DESIGN.md §6 Q4): while 1, digests go ONLY to you, never partners.
# Flip to 0 after ~2 weeks of validating the sanitizer.
DIGEST_REVIEW_MODE=1
REVIEW_RECIPIENT=engineering@bittlebits.ai

# Existing argus repo (for notify_via_email.py and its SMTP config).
ARGUS_DIR=~/PROJ/ASHANBH/personal_agents/argus
# .env file that holds SMTP_* creds (reused from focusmon).
SMTP_ENV=~/PROJ/ASHANBH/personal_agents/focusmon/.env

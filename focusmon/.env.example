# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# --- Mail (Gmail + App Password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# The account used for SMTP auth. Only the first address is used if this is a list.
SMTP_USER=you@gmail.com
# Generate at myaccount.google.com/apppasswords (16-char, no spaces)
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# Recipient for the legacy self-report CLI (sendEmailReport.py)
SMTP_TO=you@example.com

# --- Slack ---
# Incoming webhook URL from your Slack app. Set to REPLACE_ME to disable alerts.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# Prepended to every alert. Use <!here>, <!channel>, or <@USERID> syntax.
SLACK_MENTION_PREFIX=<!here> <@UXXXXXXXXX>

# --- Accountability emails ---
# Everyone on this list gets the same twice-daily and daily recap emails.
ACCOUNTABILITY_RECIPIENTS=you@example.com,partner@example.com
# Compliance % at/above which tone is "on_track" (default 70)
ACCOUNTABILITY_THRESHOLD_PCT=70
# Compliance % at/above which tone is "win" / celebrate (default 90)
ACCOUNTABILITY_WIN_THRESHOLD=90
# Name used in email subjects and body
SUBJECT_NAME=Amit
# Daily focused-hour goal for attn_daily.py
DAILY_FOCUS_GOAL_HOURS=6

# --- Detection & scheduling ---
# Absolute path to the focus log directory
LOG_DIR=/Users/you/focusmon/logs
# IANA timezone for filenames, timestamps, and work-window math
LOCAL_TZ=America/Los_Angeles
# Work window (24h, inclusive). Default: midnight–11pm (full day)
WORK_START_HOUR=0
WORK_END_HOUR=23
# Hour (24h) exempt from the "no data = drifted" penalty (e.g. lunch). -1 to disable.
LUNCH_HOUR=12
# Window Server layer threshold for Fomi's active-session overlay (default 25)
FOMI_ACTIVE_LAYER_MIN=25

# Private data — phone numbers, contacts export, match logs. Do NOT commit.
# Anchored to the agent root so the argus/ scaffolding dirs below stay tracked.
/data/
/logs/

# Argus monitoring runtime — keep the dirs (.gitkeep) but not their contents.
argus/data/*
!argus/data/.gitkeep
argus/logs/*
!argus/logs/.gitkeep

# Python / Poetry
.venv/
__pycache__/
*.pyc

# macOS
.DS_Store
